<UserControl x:Class="DeepCode.Views.MessageList"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:DeepCode.Models"
             xmlns:converters="clr-namespace:DeepCode.Views.Converters"
             d:DataContext="{d:DesignInstance Type=models:ChatViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <UserControl.Resources>
        <converters:RoleEqualsConverter x:Key="RoleEquals" />

        <Style x:Key="ChromeButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Padding" Value="4,1" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <DataTemplate x:Key="MessageTemplate" DataType="{x:Type models:DisplayMessage}">
            <Grid Margin="8,4">
                <!-- USER -->
                <Border HorizontalAlignment="Right" MaxWidth="380"
                        Background="{DynamicResource UserBubbleBg}"
                        CornerRadius="8" Padding="8"
                        Visibility="{Binding Role, Converter={StaticResource RoleEquals}, ConverterParameter=user}">
                    <TextBlock Text="{Binding Content}" TextWrapping="Wrap" />
                </Border>

                <!-- ASSISTANT -->
                <StackPanel HorizontalAlignment="Left" MaxWidth="420"
                            Visibility="{Binding Role, Converter={StaticResource RoleEquals}, ConverterParameter=assistant}">
                    <TextBlock TextWrapping="Wrap">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="{Binding Content}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsThinking}" Value="True">
                                        <Setter Property="FontStyle" Value="Italic" />
                                        <Setter Property="Foreground" Value="{DynamicResource Secondary}" />
                                        <Setter Property="FontSize" Value="11" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>

                <!-- TOOL -->
                <Expander HorizontalAlignment="Left" MaxWidth="420"
                          Visibility="{Binding Role, Converter={StaticResource RoleEquals}, ConverterParameter=tool}">
                    <Expander.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🛠 " />
                            <TextBlock Text="{Binding ToolName}" FontWeight="SemiBold" FontSize="11" />
                            <TextBlock Text=" " />
                            <TextBlock Text="{Binding ToolParams}" FontSize="11"
                                       Foreground="{DynamicResource Secondary}"
                                       TextTrimming="CharacterEllipsis" MaxWidth="280" />
                        </StackPanel>
                    </Expander.Header>
                    <StackPanel Margin="20,4,0,4">
                        <TextBlock Text="params:" FontSize="10" Foreground="{DynamicResource Secondary}" />
                        <TextBlock Text="{Binding ToolParams}" FontFamily="Consolas" FontSize="11"
                                   TextWrapping="Wrap" Margin="0,0,0,4" />
                        <TextBlock Text="result:" FontSize="10" Foreground="{DynamicResource Secondary}" />
                        <TextBlock Text="{Binding ToolResult}" FontFamily="Consolas" FontSize="11"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Expander>

                <!-- SYSTEM -->
                <TextBlock HorizontalAlignment="Center" Margin="0,2"
                           Foreground="{DynamicResource Secondary}" FontSize="11"
                           Text="{Binding Content}" TextWrapping="Wrap"
                           Visibility="{Binding Role, Converter={StaticResource RoleEquals}, ConverterParameter=system}" />
            </Grid>
        </DataTemplate>
    </UserControl.Resources>

    <ScrollViewer x:Name="Scroller" VerticalScrollBarVisibility="Auto">
        <ItemsControl x:Name="List" ItemsSource="{Binding Messages}"
                      ItemTemplate="{StaticResource MessageTemplate}" />
    </ScrollViewer>
</UserControl>
