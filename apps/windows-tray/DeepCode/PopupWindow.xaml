<Window x:Class="DeepCode.PopupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:DeepCode.Views"
        Title="DeepCode"
        Width="480" Height="640"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        AllowsTransparency="False"
        Background="White"
        WindowStartupLocation="Manual">
    <Border BorderBrush="#B0B0B0" BorderThickness="1">
        <views:ChatPopover DataContext="{Binding}" />
    </Border>
</Window>
