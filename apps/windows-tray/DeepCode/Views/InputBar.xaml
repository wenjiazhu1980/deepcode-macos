<UserControl x:Class="DeepCode.Views.InputBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:DeepCode.Models"
             xmlns:converters="clr-namespace:DeepCode.Views.Converters"
             d:DataContext="{d:DesignInstance Type=models:ChatViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <UserControl.Resources>
        <converters:StringEmptyToVisibilityConverter x:Key="StringEmptyToVis" />
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis" />
        <converters:CountToVisibilityConverter x:Key="CountToVis" />
    </UserControl.Resources>

    <StackPanel>
        <!-- Attached images strip -->
        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Height="60"
                      Visibility="{Binding AttachedImages.Count, Converter={StaticResource CountToVis}}">
            <ItemsControl ItemsSource="{Binding AttachedImages}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate><StackPanel Orientation="Horizontal" /></ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="4">
                            <Border Width="48" Height="48" CornerRadius="4" Background="#DDDDDD">
                                <Image Source="{Binding Thumbnail}" Stretch="UniformToFill" />
                            </Border>
                            <Button Content="✕" FontSize="10" Width="16" Height="16" Padding="0"
                                    HorizontalAlignment="Right" VerticalAlignment="Top"
                                    Margin="0,-6,-6,0"
                                    Click="OnRemoveImage" Tag="{Binding Id}" />
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Slash command panel -->
        <Border Visibility="{Binding ShowCommandPanel, Converter={StaticResource BoolToVis}}"
                BorderBrush="#DDDDDD" BorderThickness="0,1,0,1">
            <ScrollViewer MaxHeight="160" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding FilteredSlashCommands}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button HorizontalContentAlignment="Stretch" Padding="12,6"
                                    Background="Transparent" BorderBrush="Transparent"
                                    Click="OnSlashCommandClick" Tag="{Binding}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Label}" FontFamily="Consolas" />
                                    <TextBlock Grid.Column="2" Text="{Binding Description}"
                                               FontSize="11" Foreground="#5A5A5A"
                                               TextTrimming="CharacterEllipsis" MaxWidth="220"
                                               TextAlignment="Right" Margin="8,0,0,0" />
                                </Grid>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- Error / hint banners -->
        <Border Background="#FFF0F0" Padding="12,6"
                Visibility="{Binding StartupError, Converter={StaticResource StringEmptyToVis}}">
            <DockPanel>
                <Button DockPanel.Dock="Right" Content="✕" Background="Transparent" BorderBrush="Transparent"
                        Command="{Binding DismissErrorCommand}" />
                <Button DockPanel.Dock="Right" Content="重试" Command="{Binding RetryStartCommand}" Margin="0,0,8,0" />
                <TextBlock Text="{Binding StartupError}" Foreground="#A33" TextWrapping="Wrap" />
            </DockPanel>
        </Border>

        <Border Background="#EFF6FF" Padding="12,6"
                Visibility="{Binding SettingsHint, Converter={StaticResource StringEmptyToVis}}">
            <DockPanel>
                <Button DockPanel.Dock="Right" Content="✕" Background="Transparent" BorderBrush="Transparent"
                        Command="{Binding DismissSettingsHintCommand}" />
                <TextBlock Text="{Binding SettingsHint}" Foreground="#1666CC" TextWrapping="Wrap" />
            </DockPanel>
        </Border>

        <!-- Input row -->
        <Grid Margin="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="📎" Background="Transparent" BorderBrush="Transparent"
                    Click="OnPasteImage" ToolTip="粘贴图片 (Ctrl+V)" />

            <TextBox x:Name="InputBox" Grid.Column="1" Margin="4,0"
                     Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                     AcceptsReturn="True" TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     MinHeight="32" MaxHeight="120"
                     PreviewKeyDown="OnInputKeyDown" />

            <Button Grid.Column="2" Content="⏹" FontSize="16"
                    Command="{Binding InterruptCommand}"
                    Visibility="{Binding IsStreaming, Converter={StaticResource BoolToVis}}"
                    Background="Transparent" BorderBrush="Transparent" ToolTip="中断当前回复" />
            <Button Grid.Column="2" Content="▶" FontSize="14"
                    Command="{Binding SubmitCommand}"
                    Visibility="{Binding IsStreaming, Converter={StaticResource InverseBoolToVis}}"
                    Background="Transparent" BorderBrush="Transparent" ToolTip="发送" />
        </Grid>
    </StackPanel>
</UserControl>
